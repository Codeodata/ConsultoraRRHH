# Database
POSTGRES_USER=consultora
POSTGRES_PASSWORD=consultora_pass
POSTGRES_DB=consultora_saas
DATABASE_URL="postgresql://consultora:consultora_pass@localhost:5432/consultora_saas"

# Auth.js (NextAuth v5)
AUTH_SECRET="your-super-secret-key-min-32-chars-change-in-production"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Consultora SaaS"

# File Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Node
NODE_ENV="development"

# Cloudflare Tunnel (solo para Opción A — token fijo)
# Obtenerlo en: https://one.dash.cloudflare.com → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=""
