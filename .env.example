# Database
# Para desarrollo local con Docker:
POSTGRES_USER=consultora
POSTGRES_PASSWORD=consultora_pass
POSTGRES_DB=consultora_saas
DATABASE_URL="postgresql://consultora:consultora_pass@localhost:5432/consultora_saas"

# Para producción con Supabase:
# DATABASE_URL="postgresql://postgres.yitiwmcpvsubbaxtfhjn:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[password]@db.yitiwmcpvsubbaxtfhjn.supabase.co:5432/postgres"
DIRECT_URL=""

# Auth.js (NextAuth v5)
AUTH_SECRET="your-super-secret-key-min-32-chars-change-in-production"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Consultora SaaS"

# File Storage (Supabase Storage)
NEXT_PUBLIC_SUPABASE_URL="https://yitiwmcpvsubbaxtfhjn.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
MAX_FILE_SIZE_MB=10

# Node
NODE_ENV="development"

# Cloudflare Tunnel (solo para Opción A — token fijo)
# Obtenerlo en: https://one.dash.cloudflare.com → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=""

# MercadoPago
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN="APP_USR-..."
MP_PUBLIC_KEY="APP_USR-..."
# Opcional: secret para verificar firma de webhooks (recomendado en producción)
MP_WEBHOOK_SECRET=""
